{
	"compilerOptions": {
		"target": "ES2024",
		"lib": [
			"ES2024"
		],
		"module": "ESNext",
		"moduleResolution": "Node",
		"outDir": "dist",
		"rootDir": "./",
		"baseUrl": "./src",
		"paths": {
			"@/*": [
				"*"
			]
		},
    "jsx": "react-jsx",
		"esModuleInterop": true,
		"resolveJsonModule": true,
		"declaration": false,
		"skipLibCheck": true,
		"experimentalDecorators": true,
		"emitDecoratorMetadata": true
	},
	"include": [
		"src/**/*",
		"docs/**/*",
		"scripts/**/*"
	]
}